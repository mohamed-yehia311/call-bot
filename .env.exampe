# ==========================================
# .env.example - Template for configuration
# ==========================================

# --- Groq Configuration ---
GROQ__API_KEY=
GROQ__BASE_URL=https://api.groq.com/openai/v1
GROQ__MODEL=openai/gpt-oss-20b
GROQ__STT_MODEL=whisper-large-v3

# --- Gemini Configuration ---
GEMINI__API_KEY=
GEMINI__MODEL=gemini-2.5-flash

# --- Superlinked configuration ---
SUPERLINKED__EMBEDDING_MODEL=entence-transformers/all-MiniLM-L6-v2
SUPERLINKED__SQM_MIN_VALUE=20
SUPERLINKED__SQM_MAX_VALUE=2000
SUPERLINKED__PRICE_MIN_VALUE=100000
SUPERLINKED__PRICE_MAX_VALUE=10000000

# --- Qdrant configuration ---
QDRANT__HOST=qdrant
QDRANT__PORT=6333
QDRANT__API_KEY=
QDRANT__CLUSTER_URL=
QDRANT__USE_QDRANT_CLOUD=true

# --- Opik Configuration ---
OPIK__API_KEY=
OPIK__PROJECT_NAME=

# --- Twilio Configuration ---
TWILIO__ACCOUNT_SID=
TWILIO__AUTH_TOKEN=

# --- Application Model Selection ---
STT_MODEL=
TTS_MODEL=