# ==========================================
# .env.example - Template for configuration
# ==========================================

# --- Groq Configuration ---
GROQ__API_KEY=
GROQ__BASE_URL=https://api.groq.com/openai/v1
GROQ__MODEL=openai/gpt-oss-20b
GROQ__STT_MODEL=whisper-large-v3

# --- Gemini Configuration ---
GEMINI__API_KEY=
GEMINI__MODEL=gemini-2.5-flash

# --- Superlinked configuration ---
SUPERLINKED__EMBEDDING_MODEL=entence-transformers/all-MiniLM-L6-v2
SUPERLINKED__SQM_MIN_VALUE=20
SUPERLINKED__SQM_MAX_VALUE=2000
SUPERLINKED__PRICE_MIN_VALUE=100000
SUPERLINKED__PRICE_MAX_VALUE=10000000

# --- Qdrant configuration ---
QDRANT__HOST=qdrant
QDRANT__PORT=6333
QDRANT__API_KEY=
QDRANT__CLUSTER_URL=
QDRANT__USE_QDRANT_CLOUD=true

# --- RunPod Configuration ---
RUNPOD__API_KEY=
RUNPOD__FASTER_WHISPER_GPU_TYPE=NVIDIA GeForce RTX 4090
RUNPOD__ORPHEUS_GPU_TYPE=NVIDIA GeForce RTX 5090

# --- Faster Whisper STT Configuration ---
FASTER_WHISPER__API_URL=http://localhost:8000
FASTER_WHISPER__MODEL=Systran/faster-whisper-large-v3

# --- Orpheus TTS Configuration (RunPod) ---
ORPHEUS__API_URL=http://localhost:8000
ORPHEUS__MODEL=orpheus-3b-0.1-ft
ORPHEUS__VOICE=mia
ORPHEUS__TEMPERATURE=0.6
ORPHEUS__TOP_P=0.9
ORPHEUS__MAX_TOKENS=1200
ORPHEUS__REPETITION_PENALTY=1.1
ORPHEUS__SAMPLE_RATE=24000
ORPHEUS__DEBUG=false

# --- Together AI TTS Configuration ---
TOGETHER__API_KEY=
TOGETHER__API_URL=https://api.together.xyz/v1
TOGETHER__MODEL=canopylabs/orpheus-3b-0.1-ft
TOGETHER__VOICE=tara
TOGETHER__SAMPLE_RATE=24000

# --- Opik Configuration ---
OPIK__API_KEY=
OPIK__PROJECT_NAME=

# --- Twilio Configuration ---
TWILIO__ACCOUNT_SID=
TWILIO__AUTH_TOKEN=

# --- Application Model Selection ---
STT_MODEL=faster-whisper
TTS_MODEL=orpheus-runpod